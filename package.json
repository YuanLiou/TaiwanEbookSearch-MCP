{
  "name": "taiwan-ebook-search-mcp",
  "version": "0.1.0",
  "description": "MCP Server for searching and comparing ebook prices across Taiwan bookstores",
  "type": "module",
  "bin": {
    "taiwan-ebook-search-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "tsc -w",
    "format": "prettier --write \"src/**/*.{js,ts,md,json,yml,yaml}\"",
    "format-check": "prettier --check \"src/**/*.{js,ts,md,json,yml,yaml}\""
  },
  "keywords": [
    "mcp",
    "ebook",
    "taiwan",
    "bookstore",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{js,ts,md,json,yml,yaml}": "prettier --write"
  }
}
