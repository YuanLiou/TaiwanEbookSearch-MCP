{
  "name": "@louis383/tw-book-search-mcp",
  "version": "0.1.0",
  "description": "MCP Server for searching and comparing ebook prices across TW bookstores",
  "type": "module",
  "bin": {
    "tw-book-search-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "tsc -w",
    "format": "prettier --write \"src/**/*.{js,ts,md,json,yml,yaml}\"",
    "format-check": "prettier --check \"src/**/*.{js,ts,md,json,yml,yaml}\"",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "ebook",
    "taiwan",
    "bookstore",
    "model-context-protocol"
  ],
  "author": "Jui Yuan Liu (Ray Yuan) <louis383@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YuanLiou/TaiwanEbookSearch-MCP.git"
  },
  "homepage": "https://github.com/YuanLiou/TaiwanEbookSearch-MCP#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,ts,md,json,yml,yaml}": "prettier --write"
  }
}
